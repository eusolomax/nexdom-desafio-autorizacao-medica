<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

   <changeSet id="1" author="victor">

      <createTable tableName="regra_autorizacao">

         <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true" />
         </column>

         <column name="procedimento" type="INT" />

         <column name="idade" type="INT" />

         <column name="sexo" type="VARCHAR(1)" />

         <column name="permitido" type="BOOLEAN" />

      </createTable>

      <createTable tableName="solicitacao_autorizacao">

         <column name="id" type="BIGINT" autoIncrement="true">
            <constraints primaryKey="true" />
         </column>

         <column name="procedimento" type="INT">
            <constraints nullable="false" />
         </column>

         <column name="idade" type="INT">
            <constraints nullable="false" />
         </column>

         <column name="sexo" type="VARCHAR(1)">
            <constraints nullable="false" />
         </column>

         <column name="autorizado" type="BOOLEAN">
            <constraints nullable="false" />
         </column>

      </createTable>

   </changeSet>

</databaseChangeLog>